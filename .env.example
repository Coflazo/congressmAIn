OPENAI_API_KEY=

# LibreTranslate — run via docker compose
LIBRETRANSLATE_URL=http://localhost:5000
LIBRETRANSLATE_API_KEY=

# Mailgun — leave blank to write digests to emails/out/ instead
MAILGUN_API_KEY=
MAILGUN_DOMAIN=sandbox-xxx.mailgun.org
INBOUND_EMAIL=ai@sandbox-xxx.mailgun.org

# Frontend / email links
PUBLIC_BASE_URL=http://localhost:5173

# Admin credentials
ADMIN_EMAIL=admin@ai020.local
ADMIN_PASSWORD_HASH=
JWT_SECRET=change-me-in-production

# Database — SQLite default; swap for postgres in prod
DATABASE_URL=sqlite:///./ai020.db
# DATABASE_URL=postgresql://user:pass@localhost/ai020
