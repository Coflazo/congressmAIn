# LLM — start the fallback server first: make fallback-server
# then all AI calls route through http://localhost:4000 for free
FALLBACK_SERVER_URL=http://localhost:4000
FALLBACK_MODEL=t0-deepseek

# LibreTranslate — run via docker compose (downloads ~1-2GB of models on first boot, be patient)
LIBRETRANSLATE_URL=http://localhost:5000
LIBRETRANSLATE_API_KEY=

# Mailgun — leave blank to write digests to emails/out/ instead of actually sending
MAILGUN_API_KEY=
MAILGUN_DOMAIN=sandbox-xxx.mailgun.org
INBOUND_EMAIL=ai@sandbox-xxx.mailgun.org

# Frontend / email links
PUBLIC_BASE_URL=http://localhost:5173

# Admin credentials
ADMIN_EMAIL=admin@congressmain.local
ADMIN_PASSWORD_HASH=
JWT_SECRET=change-me-in-production

# Database — SQLite for local, swap to postgres in prod
DATABASE_URL=sqlite:///./congressmain.db
# DATABASE_URL=postgresql://user:pass@localhost/congressmain
